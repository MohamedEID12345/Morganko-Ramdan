<%- include('layout/header') %>
<div class="container text-center mt-5">
    <h2 class="animate__animated animate__fadeInDown text-white" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">🎁 كارت السعادة - هايبر مرجانكوا 🎁</h2>
    
    <div class="scratch-container mt-4 shadow-lg animate__animated animate__zoomIn" id="capture-area" 
         style="position: relative; width: 500px; height: 300px; margin: 0 auto; border-radius: 20px; overflow: hidden; border: 8px solid #fdbb2d; background: #fff; box-shadow: 0 0 25px rgba(253, 187, 45, 0.5) !important;">
        
        <!-- خلفية النتيجة -->
        <div id="prize-text" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #fff; z-index: 1;">
            <div id="result-content" class="text-dark p-3 w-100">
                <div class="spinner-border text-warning" role="status"></div>
                <p>جاري كشف الهدية...</p>
            </div>
        </div>

        <!-- الكانفاس -->
        <canvas id="scratch-canvas" width="500" height="300" style="position: absolute; top: 0; left: 0; z-index: 2; cursor: url('https://cdn-icons-png.flaticon.com/32/1435/1435105.png'), auto;"></canvas>
    </div>
    
    <p class="mt-4 text-white fw-bold animate__animated animate__pulse animate__infinite" style="font-size: 1.2rem;">حرك إصبعك يميناً ويساراً لمسح الكارت 👆</p>

    <!-- حقل كود الإدارة (مخفي جزئياً لتجربة الماستر) -->
    <div class="text-center mt-2" style="opacity: 0.2;">
        <input type="password" id="admin_key" class="form-control form-control-sm d-inline-block" 
               placeholder="كود الإدارة" style="width: 100px; font-size: 10px; background: transparent; color: white; border: 1px solid #444;">
    </div>
</div>

<audio id="winSound" src="https://assets.mixkit.co/active_storage/sfx/2020/2020-preview.mp3"></audio> 
<audio id="loseSound" src="https://assets.mixkit.co/active_storage/sfx/471/471-preview.mp3"></audio>

<!-- مكتبة تحويل الـ HTML لصورة -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<script>
const canvas = document.getElementById('scratch-canvas');
const ctx = canvas.getContext('2d');
let isDrawing = false;
let isRevealed = false;
const MASTER_CODE = "EID2026";

// 1. فحص الجهاز مع دعم كود الماستر
window.onload = async () => {
    const deviceId = localStorage.getItem('device_id');
    const savedKey = sessionStorage.getItem('active_master_key') || "";

    const res = await fetch('/scratch/check-device', { 
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ 
            device_id: deviceId,
            master_key: savedKey 
        })
    });
    const data = await res.json();
    if (!data.allowed) {
        Swal.fire({
            title: 'عفواً!',
            text: data.msg,
            icon: 'info',
            confirmButtonText: 'حسناً',
            confirmButtonColor: '#fdbb2d'
        }).then(() => window.location.href = '/');
    }
}

// 2. رسم الغلاف
const coverImg = new Image();
coverImg.crossOrigin = "anonymous"; 
coverImg.src = 'https://i.ibb.co/bhHbhjC/morgan.png'; 
coverImg.onload = () => {
    ctx.drawImage(coverImg, 0, 0, 500, 300);
    ctx.fillStyle = "rgba(180, 180, 180, 0.2)";
    ctx.fillRect(0, 0, 500, 300);
};

// 3. تأثير الخربشة
function scratch(e) {
    if (!isDrawing || isRevealed) return;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX || (e.touches ? e.touches[0].clientX : 0)) - rect.left;
    const y = (e.clientY || (e.touches ? e.touches[0].clientY : 0)) - rect.top;
    
    ctx.globalCompositeOperation = 'destination-out';
    ctx.beginPath();
    ctx.arc(x, y, 35, 0, Math.PI * 2); 
    ctx.fill();
    checkReveal();
}

function checkReveal() {
    if (isRevealed) return;
    const imageData = ctx.getImageData(0, 0, 500, 300).data;
    let transparent = 0;
    for (let i = 0; i < imageData.length; i += 4) {
        if (imageData[i + 3] < 128) transparent++;
    }
    if ((transparent / (500 * 300)) > 0.45) {
        isRevealed = true;
        canvas.style.transition = 'opacity 0.8s ease';
        canvas.style.opacity = '0';
        setTimeout(() => {
            canvas.style.display = 'none';
            triggerServerReveal();
        }, 800);
    }
}

// 4. معالجة النتيجة والواتساب ولقطة الشاشة
async function triggerServerReveal() {
    const deviceId = localStorage.getItem('device_id');
    const adminKey = document.getElementById('admin_key').value || sessionStorage.getItem('active_master_key');
    
    // تفعيل وضع الماستر إذا تم إدخال الكود
    if(adminKey === MASTER_CODE) sessionStorage.setItem('active_master_key', MASTER_CODE);

    const res = await fetch('/scratch/reveal', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ 
            device_id: deviceId,
            master_key: adminKey 
        })
    });
    const data = await res.json();
    
    const content = document.getElementById('result-content');
    if (data.isWinner) {
        document.getElementById('winSound').play();
        
        const { value: userName } = await Swal.fire({
            title: 'مبروك يا بطل! 🎉',
            text: 'اكتب اسمك لاستلام هديتك من هايبر مرجانكوا:',
            input: 'text',
            inputPlaceholder: 'ادخل اسمك هنا...',
            allowOutsideClick: false,
            confirmButtonText: 'تأكيد البيانات 🎁',
            confirmButtonColor: '#25D366'
        });

        const finalName = userName || "متسابق";
        const message = `*فائز جديد - هايبر مرجانكوا* 🌙%0A*الاسم:* ${finalName}%0A*رقم الكارت اليومي:* ${data.order}%0A*الجائزة:* ${data.amount}%0A*كود التحقق:* ${data.claimCode}`;
        const whatsappUrl = `https://wa.me/201003266111?text=${message}`;

        content.innerHTML = `
            <div class="animate__animated animate__bounceIn">
                <h3 class="text-success fw-bold">مبروك يا ${finalName}!</h3>
                <p class="fs-5 mb-1">فزت بـ: <b>${data.amount}</b></p>
                <div class="p-2 mb-2 shadow-sm bg-light border-dashed">رقم الكارت اليوم: ${data.order}</div>
                <div class="d-grid gap-2 col-8 mx-auto">
                    <button onclick="takeScreenshot()" class="btn btn-warning btn-sm">📸 حفظ صورة الجائزة</button>
                    <a href="${whatsappUrl}" class="btn btn-success btn-sm pulse">استلام عبر واتساب ✅</a>
                </div>
            </div>`;
            
        confetti({ particleCount: 200, spread: 100, origin: { y: 0.6 } });
    } else {
        document.getElementById('loseSound').play();
        content.innerHTML = `
            <div class="animate__animated animate__fadeIn">
                <h3 class="text-danger">حظ أوفر 🌙</h3>
                <p>رقم كارتك اليوم كان: ${data.order}</p>
                <p class="text-muted small">حاول مرة أخرى غداً</p>
                <a href="/" class="btn btn-primary btn-sm">العودة</a>
            </div>`;
    }
}

// دالة تصوير الشاشة (Screenshot)
function takeScreenshot() {
    const area = document.getElementById('capture-area');
    html2canvas(area).then(canvas => {
        const link = document.createElement('a');
        link.download = 'marjan-prize-' + Date.now() + '.png';
        link.href = canvas.toDataURL();
        link.click();
        Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'success',
            title: 'تم حفظ الصورة بنجاح ✅',
            showConfirmButton: false,
            timer: 2000
        });
    });
}

['mousedown', 'touchstart'].forEach(ev => canvas.addEventListener(ev, (e) => { isDrawing = true; scratch(e); e.preventDefault(); }, {passive: false}));
['mouseup', 'touchend'].forEach(ev => canvas.addEventListener(ev, () => isDrawing = false));
['mousemove', 'touchmove'].forEach(ev => canvas.addEventListener(ev, (e) => { scratch(e); e.preventDefault(); }, {passive: false}));
</script>

<style>
    .pulse { animation: pulse-animation 2s infinite; }
    @keyframes pulse-animation {
        0% { transform: scale(1); }
        50% { transform: scale(1.03); }
        100% { transform: scale(1); }
    }
    .border-dashed { border: 2px dashed #fdbb2d; border-radius: 10px; font-weight: bold; }
    #admin_key:focus { opacity: 1 !important; background: #fff !important; color: #000 !important; }
</style>
<%- include('layout/footer') %>